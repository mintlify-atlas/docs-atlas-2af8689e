  "keyFeatures": [
    "Generate map posters for any city worldwide",
    "17 built-in themes (terracotta, noir, blueprint, etc.)",
    "Multilingual support with Google Fonts integration",
    "Customizable dimensions and map radius",
    "OpenStreetMap data integration via OSMnx",
    "Road hierarchy visualization with different colors/widths",
    "Water features and parks rendering",
    "Custom coordinate override support",
    "PNG, SVG, and PDF export formats",
    "Local caching for offline usage"
  ],
  "publicApiSurface": [
    "create_map_poster.py --city <city> --country <country>",
    "--theme/-t <theme_name>",
    "--distance/-d <meters>",
    "--width/-W <inches>",
    "--height/-H <inches>",
    "--display-city/-dc <name>",
    "--display-country/-dC <name>",
    "--font-family <google_font_name>",
    "--latitude/-lat <degrees>",
    "--longitude/-long <degrees>",
    "--list-themes",
    "--all-themes",
    "--format <png|svg|pdf>",
    "create_poster()",
    "load_theme()",
    "get_coordinates()",
    "download_google_font()",
    "load_fonts()"
  ]
}
